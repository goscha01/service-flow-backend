{
    "name": "serviceflow-backend",
    "version": "1.0.0",
    "description": "Backend API for serviceflow",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "jest --verbose",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint server.js supabase.js",
        "lint:fix": "eslint server.js supabase.js --fix",
        "guard:status": "node scripts/check-job-status-writes.js",
        "ci": "npm run guard:status && npm test"
    },
    "keywords": [
        "nodejs",
        "express",
        "mysql",
        "api",
        "serviceflow"
    ],
    "author": "serviceflow Development Team",
    "license": "MIT",
    "dependencies": {
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "@geos/loghub-client": "github:goscha01/geos-loghub-client",
        "@sendgrid/mail": "^8.1.6",
        "@supabase/supabase-js": "^2.56.0",
        "axios": "^1.11.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "cron": "^2.4.4",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "fluent-ffmpeg": "^2.1.3",
        "google-auth-library": "^10.3.0",
        "googleapis": "^160.0.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.0",
        "multer": "^1.4.5-lts.2",
        "mysql2": "^3.15.0",
        "node-cron": "^4.2.1",
        "nodemailer": "^6.10.1",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "pdfkit": "^0.15.2",
        "qrcode": "^1.5.4",
        "socket.io": "^4.8.1",
        "socket.io-client": "^4.8.1",
        "stripe": "^12.18.0",
        "twilio": "^5.10.1",
        "validator": "^13.11.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.0.3",
        "jest": "^30.3.0",
        "nodemon": "^3.1.10",
        "supertest": "^7.2.2"
    }
}
